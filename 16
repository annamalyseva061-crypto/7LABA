using System;

namespace Task16_RowsWithAverageLess
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Задание 16. Строки с средним меньше заданного";
            
            Console.Write("Введите количество строк N: ");
            int N = int.Parse(Console.ReadLine());
            
            Console.Write("Введите количество столбцов M: ");
            int M = int.Parse(Console.ReadLine());
            
            int[,] matrix = new int[N, M];
            Random rnd = new Random();
            
            Console.WriteLine($"\nМатрица {N}x{M}:");
            for (int i = 0; i < N; i++)
            {
                for (int j = 0; j < M; j++)
                {
                    matrix[i, j] = rnd.Next(1, 100);
                    Console.Write(matrix[i, j] + "\t");
                }
                Console.WriteLine();
            }
            
            Console.Write("\nВведите заданную величину: ");
            double threshold = double.Parse(Console.ReadLine());
            
            int countRows = 0;
            
            for (int i = 0; i < N; i++)
            {
                int sum = 0;
                for (int j = 0; j < M; j++)
                {
                    sum += matrix[i, j];
                }
                
                double average = (double)sum / M;
                
                if (average < threshold)
                {
                    countRows++;
                    Console.WriteLine($"Строка {i + 1}: среднее = {average:F2} < {threshold}");
                }
            }
            
            Console.WriteLine($"\nКоличество строк со средним меньше {threshold}: {countRows}");
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
