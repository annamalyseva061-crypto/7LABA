using System;

namespace Task9_SwapDiagonalMinMax
{
    internal class Program
    {
        static void Main(string[] args)
        {
            Console.Title = "Задание 9. Обмен max и min на главной диагонали";
            
            Console.Write("Введите размер матрицы N: ");
            int N = int.Parse(Console.ReadLine());
            
            int[,] matrix = new int[N, N];
            Random rnd = new Random();
            
            Console.WriteLine("\nИсходная матрица:");
            for (int i = 0; i < N; i++)
            {
                for (int j = 0; j < N; j++)
                {
                    matrix[i, j] = rnd.Next(1, 100);
                    Console.Write(matrix[i, j] + "\t");
                }
                Console.WriteLine();
            }
            
            int minDiag = matrix[0, 0];
            int maxDiag = matrix[0, 0];
            int minIndex = 0;
            int maxIndex = 0;
            
            for (int i = 1; i < N; i++)
            {
                if (matrix[i, i] < minDiag)
                {
                    minDiag = matrix[i, i];
                    minIndex = i;
                }
                if (matrix[i, i] > maxDiag)
                {
                    maxDiag = matrix[i, i];
                    maxIndex = i;
                }
            }
            
            Console.WriteLine($"\nМинимальный элемент диагонали: {minDiag} (индекс {minIndex})");
            Console.WriteLine($"Максимальный элемент диагонали: {maxDiag} (индекс {maxIndex})");
            
            int temp = matrix[minIndex, minIndex];
            matrix[minIndex, minIndex] = matrix[maxIndex, maxIndex];
            matrix[maxIndex, maxIndex] = temp;
            
            Console.WriteLine("\nМатрица после обмена:");
            for (int i = 0; i < N; i++)
            {
                for (int j = 0; j < N; j++)
                {
                    Console.Write(matrix[i, j] + "\t");
                }
                Console.WriteLine();
            }
            
            Console.Write("\nНажми любую клавишу...");
            Console.ReadKey();
        }
    }
}
